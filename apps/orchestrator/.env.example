APP_NAME=rag-platform-orchestrator
NODE_ENV=development
APP_VERSION=0.0.1

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

INBOUND_QUEUE_NAME=inbound-messages
INBOUND_QUEUE_CONCURRENCY=5
INBOUND_QUEUE_ATTEMPTS=3
INBOUND_QUEUE_BACKOFF_MS=1000
FLOW_EXECUTION_QUEUE_NAME=flow-execution
FLOW_EXECUTION_QUEUE_CONCURRENCY=5
FLOW_EXECUTION_QUEUE_ATTEMPTS=3
FLOW_EXECUTION_QUEUE_BACKOFF_MS=1000

INTERNAL_API_BASE_URL=http://localhost:3001
INTERNAL_API_REQUEST_TIMEOUT_MS=10000
HTTP_RETRY_ENABLED=true
HTTP_RETRY_MAX_ATTEMPTS=3
HTTP_RETRY_INITIAL_DELAY_MS=250
HTTP_RETRY_MAX_DELAY_MS=2000
HTTP_CIRCUIT_BREAKER_ENABLED=true
HTTP_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
HTTP_CIRCUIT_BREAKER_OPEN_MS=30000
INBOUND_QUEUE_DLQ_NAME=inbound-messages-dlq
FLOW_EXECUTION_QUEUE_DLQ_NAME=flow-execution-dlq
INBOUND_QUEUE_COMPLETED_RETENTION_SECONDS=86400
INBOUND_QUEUE_FAILED_RETENTION_SECONDS=604800
FLOW_EXECUTION_QUEUE_COMPLETED_RETENTION_SECONDS=86400
FLOW_EXECUTION_QUEUE_FAILED_RETENTION_SECONDS=604800
INTERNAL_API_DOCUMENTS_REGISTER_PATH=/documents/register
INTERNAL_API_CONVERSATIONS_REPLY_PATH=/conversations/reply
INTERNAL_API_HANDOFF_PATH=/handoff
INTERNAL_API_SEARCH_PATH=/search
INTERNAL_API_MEMORY_STORE_PATH=/memory/messages
INTERNAL_API_MEMORY_CONTEXT_PATH=/memory/context
RAG_RETRIEVAL_TOP_K=5

EMAIL_LISTENER_ENABLED=true
EMAIL_LISTENER_MODE=manual
EMAIL_LISTENER_POLL_INTERVAL_MS=30000
EMAIL_LISTENER_API_BASE_URL=
EMAIL_LISTENER_API_TOKEN=
EMAIL_LISTENER_OUTBOUND_PATH=/messages/send
EMAIL_LISTENER_TIMEOUT_MS=10000
EMAIL_LISTENER_RETRY_ENABLED=true
EMAIL_LISTENER_RETRY_MAX_ATTEMPTS=3
EMAIL_LISTENER_RETRY_INITIAL_DELAY_MS=250
EMAIL_LISTENER_RETRY_MAX_DELAY_MS=2000
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_LISTENER_ENABLED=true
TELEGRAM_LISTENER_BOT_TOKEN=
TELEGRAM_LISTENER_BOT_USERNAME=
TELEGRAM_LISTENER_MODE=polling
TELEGRAM_LISTENER_POLLING_INTERVAL_MS=10000
TELEGRAM_LISTENER_WEBHOOK_SECRET=
TELEGRAM_LISTENER_API_BASE_URL=https://api.telegram.org
TELEGRAM_LISTENER_TIMEOUT_MS=10000
TELEGRAM_LISTENER_RETRY_ENABLED=true
TELEGRAM_LISTENER_RETRY_MAX_ATTEMPTS=3
TELEGRAM_LISTENER_RETRY_INITIAL_DELAY_MS=250
TELEGRAM_LISTENER_RETRY_MAX_DELAY_MS=2000
WHATSAPP_LISTENER_ENABLED=true
WHATSAPP_LISTENER_MODE=manual
WHATSAPP_LISTENER_API_BASE_URL=
WHATSAPP_LISTENER_API_TOKEN=
WHATSAPP_LISTENER_OUTBOUND_PATH=/messages
WHATSAPP_LISTENER_TIMEOUT_MS=10000
WHATSAPP_LISTENER_RETRY_ENABLED=true
WHATSAPP_LISTENER_RETRY_MAX_ATTEMPTS=3
WHATSAPP_LISTENER_RETRY_INITIAL_DELAY_MS=250
WHATSAPP_LISTENER_RETRY_MAX_DELAY_MS=2000
