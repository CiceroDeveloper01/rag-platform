{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@rag-platform/config": ["../../packages/config/src/index.ts"],
      "@rag-platform/contracts": ["../../packages/contracts/src/index.ts"],
      "@rag-platform/observability": [
        "../../packages/observability/src/index.ts"
      ],
      "@rag-platform/sdk": ["../../packages/sdk/src/index.ts"],
      "@rag-platform/shared": ["../../packages/shared/src/index.ts"],
      "@rag-platform/types": ["../../packages/types/src/index.ts"],
      "@rag-platform/utils": ["../../packages/utils/src/index.ts"]
    },
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false
  }
}
