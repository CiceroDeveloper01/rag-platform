{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build:workspace-deps": "npm --prefix ../../packages/types run build && npm --prefix ../../packages/contracts run build && npm --prefix ../../packages/utils run build",
    "prebuild": "npm run build:workspace-deps",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "pretest": "npm run build:workspace-deps",
    "test": "vitest run",
    "pretest:coverage": "npm run build:workspace-deps",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rag-platform/contracts": "file:../../packages/contracts",
    "@rag-platform/types": "file:../../packages/types",
    "@rag-platform/utils": "file:../../packages/utils",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
